{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "jsx": "preserve",
    "lib": ["ES2022", "DOM"],
    "baseUrl": "."
  },
  "exclude": ["node_modules", "**/node_modules", "dist", "**/dist"]
}
