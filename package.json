{
  "name": "opencloud-extensions",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "OpenCloud extension packages (AI sidebar, semantic search, branding, H5P, OpenClass)",
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "scripts": {
    "build": "pnpm -r build",
    "lint": "eslint packages/*/src --ext .ts,.vue",
    "format": "prettier --write \"packages/*/src/**/*.{ts,vue}\"",
    "format:check": "prettier --check \"packages/*/src/**/*.{ts,vue}\"",
    "type-check": "pnpm -r type-check",
    "check:all": "pnpm lint && pnpm format:check && pnpm type-check"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0",
    "vue-eslint-parser": "^10.4.0"
  }
}
